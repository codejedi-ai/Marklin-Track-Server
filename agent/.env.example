# Copy to .env and fill in. (The app also falls back to ../token.txt for the key.)

# --- Neo4j (matches docker-compose.yml) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cmdb-dev-password
NEO4J_DATABASE=neo4j

# --- OpenRouter (powers the /ask LlamaIndex agent) ---
OPENROUTER_API_KEY=
# Best balance for English->Cypher. Swap for any OpenRouter model id, e.g.
# openai/gpt-4o, google/gemini-2.5-pro.
ASK_MODEL=anthropic/claude-sonnet-4.5

# --- Identity resolution ---
USER_MATCH_THRESHOLD=0.85
